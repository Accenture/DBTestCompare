<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="stdout" target="SYSTEM_OUT">
            <PatternLayout pattern="[%-5p] %d %c{1}%X{testName} - %m%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <Logger name="org.nocrala.tools.texttablefmt" level="warn"/>
        <Logger name="com.mchange" level="warn"/>
        <Root level="trace">
            <AppenderRef ref="stdout"/>
        </Root>
    </Loggers>
</Configuration>
